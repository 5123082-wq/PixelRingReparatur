# PixelRing signage-service environment contract
#
# Commit this file. Do not put real secrets here.
# Server rule: configure these variables in the hosting provider, not by
# uploading .env.local.

# Required at runtime. Prisma uses POSTGRES_PRISMA_URL first, DATABASE_URL second.
POSTGRES_PRISMA_URL=
DATABASE_URL=

# Required for migration/seed commands. Use a direct/non-pooling database URL.
DIRECT_URL=
POSTGRES_URL_NON_POOLING=

# Required admin portal keys. Use two different long random values.
ADMIN_MASTER_KEY_CRM=
ADMIN_MASTER_KEY_CMS=


# Optional private local attachment storage.
# For production, prefer a durable private object store and keep files non-public.
ATTACHMENT_STORAGE_DIR=
ATTACHMENT_MAX_UPLOAD_BYTES=10485760

# Optional. Defaults to 12 hours when omitted.
ADMIN_SESSION_TTL_HOURS=12

# Optional outbound notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional public messenger links. Safe to expose to the browser.
NEXT_PUBLIC_WHATSAPP_URL=
NEXT_PUBLIC_TELEGRAM_URL=

# Optional AI assistant configuration.
# Put the real key in .env.local for local development and in hosting env vars for production.
AI_PROVIDER=openai
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
# Default temperature. The CMS AI setting overrides this after it is saved.
AI_TEMPERATURE=0.2
AI_MAX_CONTEXT_MESSAGES=20
AI_MAX_OUTPUT_TOKENS=600
AI_TIMEOUT_MS=20000
